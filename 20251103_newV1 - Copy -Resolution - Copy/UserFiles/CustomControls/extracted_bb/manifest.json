{
    "mver": "1.2.11",
    "$schema": "./CWC_manifest_Schema.json",
    "control": {
        "identity": {
            "name": "ChartJsScriptOnly",
            "version": "1.0.0", 
            "displayname": "Chart JS Script Driven",
            "icon": "./assets/ChartCamIcon.png",
            "type": "guid://de936cae-fd78-445a-871f-e616946eb2bb",
            "start": "./control/index.html"
        },
        "metadata": {
            "author": "User",
            "keywords": ["ChartJS", "Scripting"]
        },
        "contracts": {
            "api": {
                "methods": {
                    "SetTraceMode": {
                        "description": "Abilita o disabilita trace",
                        "parameters": {
                            "enable": { "type": "number", "description": "Abilitazione se diverso da zero" }
                        }
                    },
                    "ToggleTraceMode": {
                        "description": "Inverte abilitazione trace",
                        "parameters": {
                        }
                    },
                    "SetLabelStart": {
                        "description": "Imposta l'etichetta data a inizio asse X.",
                        "parameters": {
                            "text": { "type": "string", "description": "Testo data (es. '16/01/2025')" },
                            "visible": { "type": "boolean", "description": "Mostra/Nascondi" }
                        }
                    },
                    "SetLabelEnd": {
                        "description": "Imposta l'etichetta data a fine asse X.",
                        "parameters": {
                            "text": { "type": "string", "description": "Testo data" },
                            "visible": { "type": "boolean", "description": "Mostra/Nascondi" }
                        }
                    },
                    "EventsClear": {
                        "description": "Svuota la lista degli eventi.",
                        "parameters": {}
                    },
                    "EventsMaskSet": {
                        "description": "Imposta la maschera di visualizzazione eventi (es. 1=Tipo1, 2=Tipo2, 3=T1+T2).",
                        "parameters": {
                            "mask": { "type": "number", "description": "Bitmask intera" }
                        }
                    },
                    "EventsColorSet": {
                        "description": "Imposta il colore per un tipo di evento.",
                        "parameters": {
                            "type": { "type": "number", "description": "ID numerico del tipo evento (1, 2, 3...)" },
                            "colorRGB": { "type": "string", "description": "Colore (es. 'red', '#FF0000')" }
                        }
                    },
                    "EventAdd": {
                        "description": "Aggiunge un evento alla lista.",
                        "parameters": {
                            "type": { "type": "number", "description": "Tipo evento (bitmask)" },
                            "time": { "type": "number", "description": "Timestamp ms" },
                            "text": { "type": "string", "description": "Testo descrizione" }
                        }
                    },
                    "ZoomX": {
                        "description": "Esegue uno zoom sull'asse X (es. >1.0 per Zoom In, <1.0 per Zoom Out).",
                        "parameters": {
                            "factor": { "type": "number", "description": "Fattore di zoom (es. 1.2 o 0.8)" }
                        }
                    },
                    "ZoomY": {
                        "description": "Esegue uno zoom sull'asse Y (es. >1.0 per Zoom In, <1.0 per Zoom Out).",
                        "parameters": {
                            "factor": { "type": "number", "description": "Fattore di zoom (es. 1.2 o 0.8)" }
                        }
                    },
                    "PanX": {
                        "description": "Sposta la vista sull'asse X (es. 100 per vista a sinistra, -100 per vista a destra).",
                        "parameters": {
                            "pixels": { "type": "number", "description": "Quantita di pixel da spostare" }
                        }
                    },
                    "PanY": {
                        "description": "Sposta la vista sull'asse Y (es. 100 per scorrere in alto, -100 per scorrere in basso).",
                        "parameters": {
                            "pixels": { "type": "number", "description": "Quantita di pixel da spostare" }
                        }
                    },
                    "ResetZoom": {
                        "description": "Ripristina la visualizzazione iniziale e i limiti originali dell'asse X.",
                        "parameters": {}
                    },
                    "TracesSetColor": {
                        "description": "Imposta il colore di una traccia.",
                        "parameters": {
                            "index": { "type": "number", "description": "Indice della traccia (0, 1, 2)" },
                            "colorRGB": { "type": "string", "description": "Colore (es. 'rgba(255,0,0,1)')" }
                        }
                    },
                    "TracesSetThickness": {
                        "description": "Imposta lo spessore della linea di una traccia.",
                        "parameters": {
                            "index": { "type": "number", "description": "Indice della traccia (0, 1, 2)" },
                            "thickness": { "type": "number", "description": "Spessore in pixel (es. 2)" }
                        }
                    },
                    "DatasetAdd": {
                        "description": "Crea un nuovo gruppo di visualizzazione (dataset) basato sugli indici delle tracce esistenti.",
                        "parameters": {
                            "indexes": {"type": "array", "items": { "type": "number" }, "description": "Array di indici delle tracce da includere (es. [0, 2])" }
                        }
                    },
                    "DatasetSet": {
                        "description": "Sovrascrive o crea un dataset specifico con un elenco di tracce.",
                        "parameters": {
                            "index": { "type": "number", "description": "Indice del dataset da modificare (0, 1, 2...)" },
                            "indexes": { "type": "array", "items": { "type": "number" }, "description": "Array di indici delle tracce (es. [0, 2])" }
                        }
                    },
                    "DatasetClear": {
                        "description": "Svuota l'elenco dei dataset (gruppi) creati.",
                        "parameters": {}
                    },
                    "DatasetShow": {
                        "description": "Cambia il dataset visualizzato.",
                        "parameters": {
                            "index": { "type": "number", "description": "Indice del dataset (0, 1, 2)" }
                        }
                    },
                    "TracesAdd": {
                        "description": "Aggiunge traccia e scatena evento OnTraceAdded",
                        "parameters": {
                            "colorRGB": { "type": "string" },
                            "yAxisId": { "type": "string" },
                            "lblName": { "type": "string" }
                        }
                    },
                    "TracesClear": {
                        "description": "Svuota i dati delle tracce mantenendo colori e configurazioni.",
                        "parameters": {}
                    },
                    "AddAxisY": {
                        "description": "Aggiunge un asse Y.",
                        "parameters": {
                            "axisId": { "type": "string", "description": "ID dell'asse (es. 'y', 'y1')" },
                            "position": { "type": "string", "description": "Posizione ('left', 'right')" },
                            "gridcolor": { "type": "string", "description": "Colore linee griglia" }
                        }
                    },
                    "AxisSetTitle": {
                        "description": "Imposta il titolo/unita di misura di un asse.",
                        "parameters": {
                            "axisId": { "type": "string", "description": "ID asse (es. 'x', 'y', 'y1')" },
                            "text": { "type": "string", "description": "Testo (es. 'Temperatura [C]')" },
                            "color": { "type": "string", "description": "Colore (opzionale, es. 'red')" }
                        }
                    },
                    "AxisYClear": {
                        "description": "Rimuove tutti gli assi Y configurati (mantiene l'asse X).",
                        "parameters": {}
                    },
                    "AxisYVisible": {
                        "description": "Mostra o nasconde un asse specifico.",
                        "parameters": {
                            "axisId": { "type": "string", "description": "ID dell'asse (es. 'y1')" },
                            "visible": { "type": "boolean", "description": "True per mostrare, False per nascondere" }
                        }
                    },
                    "AxisYMinMax": {
                        "description": "Imposta Min e Max per un asse. Passare NaN per Auto-Scale.",
                        "parameters": {
                            "axisId": { "type": "string", "description": "ID dell'asse (es. 'y1')" },
                            "min": { "type": "number", "description": "Valore Minimo (o NaN)" },
                            "max": { "type": "number", "description": "Valore Massimo (o NaN)" }
                        }
                    },
                    "UpdateChart": {
                        "description": "Forza il refresh del grafico.",
                        "parameters": {
                            "none": { "type": "boolean", "description": "se true chiama con 'none'" }
                        }
                    },
		"GetExportSettings": {
    			"description": "Returns current export settings (paper, orientation, width, height)",
   			 "parameters": {},
   			 "returns": "object"
		},
		"GetChartBase64": {
    			"description": "Returns chart as Base64 PNG image",
   			 "parameters": {},
   			 "returns": "string"
		},
		"GetChartSVG": {
    			"description": "Returns chart as SVG XML string",
   			 "parameters": {},
   			 "returns": "string"
		},
                    "CheckTimeAxis": {
                        "description": "Aggiorna l'asse dei tempi.",
                        "parameters": {}
                    },
                    "TracesSetPoints": {
                        "description": "Aggiunge o aggiorna tutte le tracce del grafico simultaneamente",
                        "parameters": {
                            "append": { "type": "bool", "description": "Se true, appende alle tracce" },
                            "matrix": { "type": "array", "items" : { "type" : "array" , "items" : { "type" : "object"} }, "description": "Array di array che contengono tutti i punti di tutte le tracce" }
                        }
                    }
                },
                "events": {
                    "trace" : {
                        "arguments" : {
                            "text" : { "type" : "string" }
                        },
                        "description" : "Chiama HMITrace"
                    },
                    "chartBase64" : {
                        "arguments" : {
                            "data" : { "type" : "string" }
                        },
                        "description" : "Returns chart as Base64 JPEG image"
                    },
                    "chartSVG" : {
                        "arguments" : {
                            "data" : { "type" : "string" }
                        },
                        "description" : "Returns chart as SVG XML string"
                    }
                },
                "properties": {
                    "TimeWindowMinutes": { "type": "number", "default": 30 },
                    "TimeExtensionMinutes": { "type": "number", "default": 5 },
                    "EnableDebugLog": { "type": "boolean", "default": false },
                    "ChartBase64Data": { "type": "string", "default": "" },
                    "ChartSVGData": { "type": "string", "default": "" }
                }
            }
        },
        "types": {}
    }
}
